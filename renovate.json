{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "customManagers": [
        {
            "customType": "regex",
            "datasourceTemplate": "deb",
            "managerFilePatterns": [
                "/^Dockerfile$/"
            ],
            "matchStrings": [
                "#\\s*renovate:\\s*?(suite=(?<suite>.*?))?\\s*depName=(?<depName>.*?)?\\s(ARG|ENV) .*?_VERSION=\"(?<currentValue>.*)\""
            ],
            "registryUrlTemplate": "https://deb.debian.org/debian?suite={{#if suite }}{{suite}}{{else}}stable{{/if}}&components=main,contrib,non-free&binaryArch=amd64",
            "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}deb{{/if}}"
        },
        // {
        //     "customType": "regex",
        //     "description": "Update GitHub Actions runner labels in matrix.os",
        //     "datasourceTemplate": "github-runners",
        //     "packageNameTemplate": "{{platform}}",
        //     "versioningTemplate": "docker",
        //     "managerFilePatterns": [
        //         "/^\\.github\\/workflows\\/.*\\.ya?ml$/"
        //     ],
        //     "matchStrings": [
        //         "(?<prefix>(?:^|\\r\\n|\\r|\\n)[^\\S\\r\\n]*-[^\\S\\r\\n]*(?<platform>ubuntu|macos|windows)-)(?<currentValue>latest|\\d{2}\\.\\d{2}|\\d{4}|\\d{2})(?<suffix>[^\\S\\r\\n]*#[^\\S\\r\\n]*renovate:[^\\S\\r\\n]*runner[^\\S\\r\\n]*)"
        //     ],
        //     "autoReplaceStringTemplate": "{{prefix}}{{newValue}}{{suffix}}"
        // },
        {
            "customType": "regex",
            "description": "Update Windows runner label in matrix.os",
            "datasourceTemplate": "github-runners",
            "packageNameTemplate": "windows",
            "versioningTemplate": "docker",
            "managerFilePatterns": [
                "/^\\.github\\/workflows\\/test\\.ya?ml$/"
            ],
            "matchStrings": [
                "(?m)^(?<prefix>\\s*-\\s*windows-)(?<currentValue>latest|\\d{4})(?<suffix>\\s*#\\s*renovate:\\s*runner\\s*)$"
            ],
            "autoReplaceStringTemplate": "{{prefix}}{{newValue}}{{suffix}}"
        }
    ],
    "extends": [
        "config:best-practices"
    ],
    "lockFileMaintenance": {
        "automerge": true,
        "enabled": true
    },
    "packageRules": [
        {
            "automerge": true,
            "matchDepTypes": [
                "devDependencies"
            ],
            "matchPackageNames": [
                "ruff",
                "ty"
            ]
        },
        {
            "automerge": true,
            "matchCurrentVersion": "!/^0/",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        }
    ],
    "pre-commit": {
        "enabled": true
    }
}
